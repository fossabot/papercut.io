{
  "name": "papercut.io",
  "private": true,
  "version": "1.4.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "tauri": "tauri",
    "tauri:dev": "tauri dev --features native-tts-shared",
    "build": "npm run build:typecheck && npm run build:vite && npm run build:search-index",
    "build:typecheck": "tsc -b",
    "build:vite": "vite build",
    "build:search-index": "npx pagefind --site dist --glob \"documents/**/*.html\"",
    "browser": "npm run build && vite preview",
    "preview": "vite preview",
    "lint": "eslint .",
    "desktop": "node scripts/build-desktop.js",
    "desktop:static": "node scripts/build-desktop.js --static",
    "verify:appimage-media": "node scripts/verify-appimage-media.js",
    "android:apk": "node scripts/build-android.js",
    "android:apk:native-tts": "node scripts/build-android.js --native-tts",
    "prepare:jdk": "node scripts/prepare-local-jdk.js",
    "prepare:jdk:force": "node scripts/prepare-local-jdk.js --force",
    "prepare:sherpa-android-libs": "node scripts/prepare-sherpa-android-libs.js",
    "prepare:sherpa-android-libs:force": "node scripts/prepare-sherpa-android-libs.js --force",
    "ios:init": "node scripts/build-ios.js --init",
    "ios:ipa": "node scripts/build-ios.js",
    "ios:ipa:native-tts": "node scripts/build-ios.js --native-tts",
    "ios:ci": "node scripts/build-ios.js --ci-check",
    "prepare:sherpa-ios-libs": "node scripts/prepare-sherpa-ios-libs.js",
    "prepare:sherpa-ios-libs:force": "node scripts/prepare-sherpa-ios-libs.js --force"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-aria-components": "^1.19.0",
    "react-dom": "^19.2.0",
    "tauri-plugin-native-audio-api": "1.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "pagefind": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
